{
  "name": "@fieldsy/stripe-auto-payout",
  "version": "1.0.0",
  "description": "Standalone Stripe Connect auto-payout engine with subscriptions, refunds, and lifecycle tracking",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "express": "^4.18.0 || ^5.0.0",
    "stripe": "^14.0.0 || ^15.0.0 || ^16.0.0 || ^17.0.0",
    "node-cron": "^3.0.0"
  },
  "peerDependenciesMeta": {
    "express": { "optional": false },
    "stripe": { "optional": false },
    "node-cron": { "optional": true }
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/express": "^4.17.0 || ^5.0.0",
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.0",
    "stripe": "^17.0.0",
    "express": "^4.21.0"
  },
  "keywords": [
    "stripe",
    "stripe-connect",
    "payout",
    "auto-payout",
    "subscription",
    "recurring-billing",
    "marketplace",
    "platform"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  }
}
